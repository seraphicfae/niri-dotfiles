#!/usr/bin/env bash
# Creator : Faye | https://github.com/seraphicfae/niri-dotfiles

zscroll -l 20 \
        --delay 0.2 \
        --scroll-padding " • " \
        --match-command "playerctl status 2>/dev/null" \
        --match-text "Playing" "--scroll 1" \
        --match-text "Paused" "--scroll 1" \
        --update-check true "playerctl metadata --format '{{title}} - {{artist}}' 2>/dev/null" &
wait
