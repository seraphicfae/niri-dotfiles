  "languages": {
    "Astro": {
      "extension": "astro",
      "path": "languages/astro",
      "matcher": {
        "path_suffixes": [
          "astro"
        ],
        "first_line_pattern": null,
        "modeline_aliases": []
      },
      "hidden": false,
      "grammar": "astro"
    },
    "Git Attributes": {
      "extension": "git-firefly",
      "path": "languages/gitattributes",
      "matcher": {
        "path_suffixes": [
          "gitattributes",
          ".gitattributes"
        ],
        "first_line_pattern": null,
        "modeline_aliases": []
      },
      "hidden": false,
      "grammar": "gitattributes"
    },
    "Git Config": {
      "extension": "git-firefly",
      "path": "languages/gitconfig",
      "matcher": {
        "path_suffixes": [
          "config.worktree",
          ".gitconfig",
          ".gitmodules",
          ".lfsconfig"
